---
import Layout from '../layouts/Layout.astro';
import ModernHeader from '../components/ModernHeader.astro';
import ModernFooter from '../components/ModernFooter.astro';
---

<Layout 
	title="Publications - SAAIL Lab"
	description="Explore our research publications, academic papers, and scholarly contributions in AI for agriculture, healthcare, and responsible AI at SAAIL Lab, IIT Madras Zanzibar."
>
	<ModernHeader />
	
	<main class="publications-page">
		<!-- Hero Section -->
		<section class="publications-hero">
			<div class="container">
				<div class="hero-content">
					<div class="hero-icon">
						<svg width="100" height="100" viewBox="0 0 120 120" fill="none">
							<!-- Outer glow ring -->
							<circle cx="60" cy="60" r="55" stroke="url(#publicationGradient)" stroke-width="2" fill="none" opacity="0.3"/>
							<circle cx="60" cy="60" r="48" stroke="url(#publicationGradient)" stroke-width="1.5" fill="none" opacity="0.5"/>
							
							<!-- Main document stack -->
							<rect x="30" y="25" width="50" height="65" rx="8" fill="url(#documentGradient)" opacity="0.9"/>
							<rect x="35" y="30" width="50" height="65" rx="8" fill="url(#documentGradient2)" opacity="0.8"/>
							<rect x="40" y="35" width="50" height="65" rx="8" fill="white" stroke="url(#publicationGradient)" stroke-width="2"/>
							
							<!-- Document lines -->
							<line x1="48" y1="45" x2="82" y2="45" stroke="url(#publicationGradient)" stroke-width="2" opacity="0.7"/>
