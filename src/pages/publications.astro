						<button class="filter-tab" data-filter="2025">2025</button>
						<button class="filter-tab" data-filter="2024">2024</button>
						<button class="filter-tab" data-filter="journal">Journal Articles</button>
						<button class="filter-tab" data-filter="conference">Conference Papers</button>
					</div>
				</div>
			</div>
		</section>

