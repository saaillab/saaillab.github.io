---
import Layout from '../layouts/Layout.astro';
import ModernHeader from '../components/ModernHeader.astro';
import ModernFooter from '../components/ModernFooter.astro';
---

<Layout 
	title="People - SAAIL Lab"
	description="Meet the team at SAAIL Lab - our principal investigator, current students, collaborators, and alumni driving AI innovation for sustainable agriculture and intelligent livelihoods."
>
	<ModernHeader />
	
	<main class="people-page">
		<!-- Hero Section -->
		<section class="people-hero">
			<div class="container">
				<div class="hero-content">
					<h1>Our Team</h1>
					<p class="hero-description">
						Meet the researchers, students, and collaborators driving innovation at SAAIL Lab, 
						working together to create transformative AI solutions for East Africa.
					</p>
				</div>
			</div>
		</section>

		<!-- Main Content -->
		<section class="people-content">
			<div class="container">
				<div class="people-layout">
