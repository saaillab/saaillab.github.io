---
import Layout from '../layouts/Layout.astro';
import ModernHeader from '../components/ModernHeader.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import PhDBanner from '../components/PhDBanner.astro';
import ModernFooter from '../components/ModernFooter.astro';
---

<Layout 
	title="SAAIL Lab - Sustainable AI for Agriculture & Intelligent Livelihoods"
	description="SAAIL Lab at IIT Madras Zanzibar pioneers transformative AI solutions for sustainable agriculture and intelligent livelihoods in East Africa through ethical research and innovation."
>
	<ModernHeader />
	
	<!-- Modern Hero Section -->
	<section class="modern-hero">
		<div class="hero-background">
			<div class="hero-pattern"></div>
		</div>
		<div class="container">
			<div class="hero-content">
				<div class="hero-text">
					<h1 class="hero-title">
						<span class="title-highlight">SAAIL Lab</span>
						<span class="title-subtitle">Sustainable AI for Agriculture & Intelligent Livelihoods</span>
					</h1>
					<p class="hero-description">
						Pioneering transformative, ethical, and contextually-aware Artificial Intelligence solutions 
						for East Africa. Revolutionizing sustainable agriculture, enhancing food security, 
						and improving farmer livelihoods through cutting-edge AI research and innovation.
					</p>
					<div class="hero-stats">
						<div class="stat-item">
							<span class="stat-number">3+</span>
							<span class="stat-label">Research Areas</span>
						</div>
						<div class="stat-item">
							<span class="stat-number">6+</span>
							<span class="stat-label">Active Projects</span>
						</div>
						<div class="stat-item">
							<span class="stat-number">22+</span>
							<span class="stat-label">Publications</span>
						</div>
						<div class="stat-item">
							<span class="stat-number">5+</span>
							<span class="stat-label">Collaborations</span>
						</div>
					</div>
					<div class="hero-actions">
						<a href="/research" class="btn btn-primary">Explore Research</a>
						<a href="/projects" class="btn btn-secondary">View Projects</a>
						<a href="/people" class="btn btn-outline">Meet Our Team</a>
					</div>
				</div>
				<div class="hero-visual">
					<div class="research-cards">
						<div class="research-card">
							<div class="card-icon">🌾</div>
							<h3>AI for Agriculture</h3>
							<p>Precision crop management and sustainable farming</p>
						</div>
						<div class="research-card">
							<div class="card-icon">🏥</div>
							<h3>Healthcare AI</h3>
							<p>Medical imaging and assistive technologies</p>
						</div>
						<div class="research-card">
							<div class="card-icon">⚖️</div>
							<h3>Responsible AI</h3>
							<p>Ethical frameworks for African contexts</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Team Showcase -->
	<section class="team-showcase">
		<div class="container">
			<h2 class="section-title">Our Research Team</h2>
			<p class="section-description">
				Meet the dedicated researchers and students driving innovation at SAAIL Lab
			</p>
			
			<!-- Principal Investigator -->
			<div class="pi-section">
				<div class="pi-card">
					<div class="pi-image">
						<picture>
							<source srcset="/images/people/profile.webp" type="image/webp">
							<img
								src="/images/people/profile-optimized.jpg"
								alt="Dr. Innocent Nyalala"
								class="pi-photo"
								width="120"
								height="120"
								loading="eager"
							/>
						</picture>
					</div>
					<div class="pi-info">
						<h3>Dr. Innocent Nyalala</h3>
						<p class="pi-title">Assistant Professor & Founding Principal Investigator</p>
						<p class="pi-department">School of Engineering and Sciences<br>IIT Madras Zanzibar</p>
						<div class="pi-links">
							<a href="https://inyalala.github.io" target="_blank" class="pi-link">Personal Website</a>
							<a href="mailto:innocent@iitmz.ac.in" class="pi-link">Email</a>
							<a href="https://scholar.google.com/citations?user=jYVzIZUAAAAJ&hl=en" target="_blank" class="pi-link">Google Scholar</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Current Students -->
			<div class="students-section">
				<h3 class="subsection-title">Current Students</h3>
				<div class="students-grid">
					<div class="student-card">
						<div class="student-image">
							<div class="image-placeholder">
								<span>PN</span>
							</div>
						</div>
						<div class="student-info">
							<h4>Patrick Ndowo</h4>
							<p class="student-degree">MTech Student</p>
							<p class="student-project">Deep Learning for Zanzibar Cloves Quality Grading</p>
							<div class="student-social">
								<a href="https://www.linkedin.com/in/patrick-ndowo/" target="_blank" class="social-icon">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<div class="student-card">
						<div class="student-image">
							<div class="image-placeholder">
								<span>TM</span>
							</div>
						</div>
						<div class="student-info">
							<h4>Twamaa Makame</h4>
							<p class="student-degree">MTech Student</p>
							<p class="student-project">Placental Weight & Volume Estimation from 2D Ultrasound</p>
							<div class="student-social">
								<a href="https://www.linkedin.com/in/twamaa-makame-1b2349197/" target="_blank" class="social-icon">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<div class="student-card">
						<div class="student-image">
							<div class="image-placeholder">
								<span>SV</span>
							</div>
						</div>
						<div class="student-info">
							<h4>Shivam Vyas</h4>
							<p class="student-degree">MTech Student</p>
							<p class="student-project">E-Vision: Assistive Application for Visually Impaired</p>
							<div class="student-social">
								<a href="https://www.linkedin.com/in/shivam-vyas-a98a72153/" target="_blank" class="social-icon">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Recent News and Publications -->
	<section class="recent-highlights">
		<div class="container">
			<h2 class="section-title">Recent News and Publications</h2>
			<div class="highlights-grid">
				<div class="highlight-card">
					<div class="highlight-category">Editorial Board</div>
					<h3>Appointed as Editorial Board Member - Discover Artificial Intelligence</h3>
					<p>Honored to join the editorial board of Discover Artificial Intelligence, a Springer Nature open access journal advancing AI research and innovation globally</p>
					<div class="highlight-date">December 9, 2025</div>
					<a href="https://link.springer.com/journal/44163/editorial-board" target="_blank" class="highlight-link">
						View Editorial Board →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Invited Talk</div>
					<h3>ZRCP 4th Joint Annual Conference</h3>
					<p>Invited presentation: "How Can Innovation Modernize Public Service Delivery and Create an Inclusive Digital Economy"</p>
					<div class="highlight-date">August 27, 2025</div>
					<a href="https://www.linkedin.com/in/innocentnyalala/" target="_blank" class="highlight-link">
						View Conference →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Presentation</div>
					<h3>Oral Presentation at Responsible AI Workshop</h3>
					<p>Presented CARA-FMs research at the Responsible AI Workshop, Deep Learning Indaba 2025</p>
					<div class="highlight-date">August 22, 2025</div>
					<a href="https://www.linkedin.com/in/innocentnyalala/" target="_blank" class="highlight-link">
						View Presentation →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Award</div>
					<h3>Best Poster Award - Deep Learning Indaba 2025</h3>
					<p>Won Best Poster Award in Publication & Dataset Category at Deep Learning Indaba 2025, Kigali</p>
					<div class="highlight-date">August 20, 2025</div>
					<a href="https://www.linkedin.com/in/innocentnyalala/" target="_blank" class="highlight-link">
						View Award →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Conference Publication</div>
					<h3>CARA-FMs Framework Accepted at Deep Learning Indaba 2025</h3>
					<p>Context-Aware and Responsible AI Framework for East Africa accepted at Deep Learning Indaba 2025, Kigali, Rwanda</p>
					<div class="highlight-date">August 17, 2025</div>
					<a href="https://www.linkedin.com/in/innocentnyalala/" target="_blank" class="highlight-link">
						View Details →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Research Milestone</div>
					<h3>SAAIL Lab Research Impact Grows</h3>
					<p>Lab publications reach 22+ papers with 830+ citations, establishing strong research presence in AI for agriculture</p>
					<div class="highlight-date">August 15, 2025</div>
					<a href="/publications" class="highlight-link">
						View Publications →
					</a>
				</div>

				<div class="highlight-card">
					<div class="highlight-category">Team Achievement</div>
					<h3>MTech Students Present Research Progress</h3>
					<p>Patrick Ndowo, Twamaa Makame, and Shivam Vyas present significant progress in their respective AI research projects</p>
					<div class="highlight-date">August 10, 2025</div>
					<a href="/people#current" class="highlight-link">
						Meet the Team →
					</a>
				</div>
			</div>
			<div class="highlights-cta">
				<a href="/news" class="btn btn-primary">Read More News</a>
				<a href="/publications" class="btn btn-secondary">View Publications</a>
			</div>
		</div>
	</section>

	<ModernFooter />
</Layout>

<style>
	/* Modern Hero Section */
	.modern-hero {
		position: relative;
		min-height: 90vh;
		display: flex;
		align-items: center;
		background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
		overflow: hidden;
		padding-top: 180px;
	}


	.hero-background {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		opacity: 0.1;
	}

	.hero-pattern {
		width: 100%;
		height: 100%;
		background-image: 
			radial-gradient(circle at 25% 25%, #1e3a8a 2px, transparent 2px),
			radial-gradient(circle at 75% 75%, #059669 2px, transparent 2px);
		background-size: 100px 100px;
		background-position: 0 0, 50px 50px;
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1fr 400px;
		gap: 4rem;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	.hero-title {
		margin-bottom: 2rem;
	}

	.title-highlight {
		display: block;
		font-size: 4rem;
		font-weight: 800;
		background: linear-gradient(135deg, #1e3a8a 0%, #059669 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1.1;
		margin-bottom: 0.5rem;
	}

	.title-subtitle {
		display: block;
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--text-secondary);
		line-height: 1.3;
	}

	.hero-description {
		font-size: 1.125rem;
		color: var(--text-secondary);
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.lab-cta {
		margin-top: 1.5rem;
	}

	.message-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
		color: white;
		padding: 0.75rem 1.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
	}

	.message-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(220, 38, 38, 0.4);
		background: linear-gradient(135deg, #b91c1c 0%, #dc2626 100%);
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.stat-item {
		text-align: center;
		padding: 1rem;
		background: var(--bg-secondary);
		border-radius: 0.75rem;
		box-shadow: 0 2px 8px var(--shadow-light);
		border: 1px solid var(--border-color);
	}

	.stat-number {
		display: block;
		font-size: 1.75rem;
		font-weight: 700;
		color: #1e3a8a;
	}

	.stat-label {
		font-size: 0.875rem;
		color: var(--text-muted);
		font-weight: 500;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 0.875rem 1.75rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.3s ease;
		border: 2px solid transparent;
	}

	.btn-primary {
		background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
		color: white;
		box-shadow: 0 4px 12px rgba(30, 58, 138, 0.3);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(30, 58, 138, 0.4);
	}

	.btn-secondary {
		background: linear-gradient(135deg, #059669 0%, #047857 100%);
		color: white;
		box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
	}

	.btn-secondary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(5, 150, 105, 0.4);
	}

	.btn-outline {
		background: var(--bg-secondary);
		color: #1e3a8a;
		border-color: #1e3a8a;
	}

	.btn-outline:hover {
		background: #1e3a8a;
		color: white;
		transform: translateY(-2px);
	}

	.research-cards {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.research-card {
		background: var(--bg-secondary);
		border-radius: 0.75rem;
		padding: 1.25rem;
		box-shadow: 0 4px 12px var(--shadow-light);
		border: 1px solid var(--border-color);
		transition: all 0.3s ease;
	}

	.research-card:hover {
		transform: translateX(8px);
		box-shadow: 0 8px 20px var(--shadow-medium);
	}

	.card-icon {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.research-card h3 {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 0.25rem;
	}

	.research-card p {
		color: var(--text-muted);
		font-size: 0.875rem;
		line-height: 1.4;
	}

	/* Team Showcase */
	.team-showcase {
		padding: 5rem 0;
		background: var(--bg-primary);
	}

	.section-title {
		text-align: center;
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 1rem;
	}

	.section-description {
		text-align: center;
		font-size: 1.125rem;
		color: var(--text-secondary);
		margin-bottom: 3rem;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.pi-section {
		margin-bottom: 4rem;
	}

	.pi-card {
		background: var(--bg-secondary);
		border-radius: 1.5rem;
		padding: 2.5rem;
		box-shadow: 0 8px 24px var(--shadow-light);
		border: 2px solid #1e3a8a;
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.pi-image {
		flex-shrink: 0;
	}

	.pi-avatar {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		background: linear-gradient(135deg, #1e3a8a 0%, #059669 100%);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.5rem;
		font-weight: 800;
		border: 4px solid var(--accent-blue);
		box-shadow: 0 8px 24px rgba(30, 58, 138, 0.3);
		letter-spacing: 2px;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.pi-avatar:hover {
		transform: scale(1.05);
		box-shadow: 0 12px 32px rgba(30, 58, 138, 0.4);
	}

	.pi-photo {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
		border: 4px solid var(--accent-blue);
	}

	.image-placeholder {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.25rem;
		font-weight: 700;
	}

	.pi-info h3 {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}

	.pi-title {
		font-size: 1.125rem;
		color: #059669;
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.pi-department {
		color: var(--text-secondary);
		margin-bottom: 1.5rem;
		line-height: 1.5;
	}

	.pi-links {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	.pi-link {
		color: #1e3a8a;
		text-decoration: none;
		font-weight: 500;
		padding: 0.5rem 1rem;
		border: 1px solid #1e3a8a;
		border-radius: 0.5rem;
		transition: all 0.3s ease;
	}

	.pi-link:hover {
		background: #1e3a8a;
		color: white;
	}

	.subsection-title {
		font-size: 1.75rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 2rem;
		text-align: center;
	}

	.students-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.student-card {
		background: var(--bg-secondary);
		border-radius: 1rem;
		padding: 1.5rem;
		text-align: center;
		box-shadow: 0 4px 12px var(--shadow-light);
		border: 1px solid var(--border-color);
		transition: all 0.3s ease;
	}

	.student-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 20px var(--shadow-medium);
	}

	.student-image {
		margin-bottom: 1rem;
	}

	.student-card .image-placeholder {
		width: 80px;
		height: 80px;
		font-size: 1.25rem;
		margin: 0 auto;
	}

	.student-info h4 {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 0.25rem;
	}

	.student-degree {
		color: #059669;
		font-weight: 500;
		margin-bottom: 0.75rem;
