---
import Layout from '../layouts/Layout.astro';
import ModernHeader from '../components/ModernHeader.astro';
import ModernFooter from '../components/ModernFooter.astro';
---

<Layout 
	title="Gallery - SAAIL Lab"
	description="Explore photos and visual content from SAAIL Lab at IIT Madras Zanzibar. Research activities, lab facilities, team events, and collaborative projects."
>
	<ModernHeader />
	
	<main class="gallery-page">
		<!-- Hero Section -->
		<section class="gallery-hero">
			<div class="container">
				<div class="hero-content">
					<div class="hero-icon">
						<div class="professional-icon">
							<svg width="80" height="80" viewBox="0 0 120 120" fill="none">
								<!-- Outer ring -->
								<circle cx="60" cy="60" r="55" stroke="url(#heroGradient)" stroke-width="3" fill="none" opacity="0.3"/>
								<circle cx="60" cy="60" r="45" stroke="url(#heroGradient)" stroke-width="2" fill="none" opacity="0.5"/>
								
								<!-- Camera body -->
								<rect x="35" y="40" width="50" height="35" rx="8" fill="url(#heroGradient)" opacity="0.9"/>
								<rect x="30" y="35" width="60" height="45" rx="10" stroke="url(#heroGradient)" stroke-width="2" fill="none"/>
								
								<!-- Lens -->
								<circle cx="60" cy="57" r="12" fill="white" opacity="0.9"/>
								<circle cx="60" cy="57" r="8" stroke="url(#heroGradient)" stroke-width="2" fill="none"/>
								<circle cx="60" cy="57" r="4" fill="url(#heroGradient)"/>
								
								<!-- Flash -->
								<rect x="45" y="30" width="8" height="6" rx="2" fill="white" opacity="0.8"/>
								
								<!-- Viewfinder -->
								<rect x="70" y="30" width="6" height="4" rx="1" fill="white" opacity="0.6"/>
								
								<!-- Decorative elements -->
								<circle cx="25" cy="25" r="2" fill="url(#heroGradient)" opacity="0.4"/>
								<circle cx="95" cy="35" r="1.5" fill="url(#heroGradient)" opacity="0.3"/>
								<circle cx="20" cy="95" r="1" fill="url(#heroGradient)" opacity="0.5"/>
								<circle cx="100" cy="85" r="2.5" fill="url(#heroGradient)" opacity="0.2"/>
								
								<!-- Gradient definitions -->
								<defs>
									<linearGradient id="heroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
										<stop offset="0%" style="stop-color:#667eea"/>
										<stop offset="50%" style="stop-color:#764ba2"/>
										<stop offset="100%" style="stop-color:#f093fb"/>
									</linearGradient>
								</defs>
							</svg>
						</div>
					</div>
					<h1>Research Gallery</h1>
					<p class="hero-description">
						Explore our research journey through conference presentations, publications, 
						lab activities, and collaborative achievements.
					</p>
				</div>
			</div>
		</section>

		<!-- Gallery Content -->
		<section class="gallery-content">
			<div class="container">
				<!-- Filter Tabs -->
				<div class="gallery-filters">
					<button class="filter-btn active" data-filter="all">All</button>
					<button class="filter-btn" data-filter="conferences">Conference Presentations</button>
					<button class="filter-btn" data-filter="research">Research Activities</button>
					<button class="filter-btn" data-filter="lab">Lab Facilities</button>
					<button class="filter-btn" data-filter="collaborations">Collaborations</button>
				</div>

				<!-- Gallery Grid -->
				<div class="gallery-grid" id="galleryGrid">
					<!-- Conference Presentations -->
					<div class="gallery-item featured" data-category="conferences">
						<div class="gallery-card poster-card" data-poster="/DLI Poster_ CARA-FM.jpg">
							<div class="poster-container">
								<img src="/DLI Poster_ CARA-FM.jpg" alt="CARA-FM Framework Poster" class="poster-image">
								<div class="poster-overlay">
									<div class="zoom-icon">
										<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="11" cy="11" r="8"></circle>
											<path d="M21 21l-4.35-4.35"></path>
											<line x1="11" y1="8" x2="11" y2="14"></line>
											<line x1="8" y1="11" x2="14" y2="11"></line>
										</svg>
									</div>
									<p>Click to view full size</p>
								</div>
							</div>
							<div class="gallery-info">
								<div class="conference-badge">Deep Learning Indaba 2025</div>
								<h3>CARA-FMs Framework Research</h3>
								<p>Submission of Context-Aware Responsible AI Framework Models for East Africa</p>
								<div class="gallery-meta">
									<span class="gallery-date">August 2025</span>
									<span class="gallery-location">Kigali, Rwanda</span>
								</div>
							</div>
						</div>
					</div>

					<div class="gallery-item featured" data-category="conferences">
						<div class="gallery-card poster-card" data-poster="/Beige and White Contemporary Editorial Landscape University Research Poster.png">
							<div class="poster-container">
								<img src="/Beige and White Contemporary Editorial Landscape University Research Poster.png" alt="DSA 2025 Research Poster" class="poster-image">
								<div class="poster-overlay">
									<div class="zoom-icon">
										<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="11" cy="11" r="8"></circle>
											<path d="M21 21l-4.35-4.35"></path>
											<line x1="11" y1="8" x2="11" y2="14"></line>
											<line x1="8" y1="11" x2="14" y2="11"></line>
										</svg>
									</div>
									<p>Click to view full size</p>
								</div>
							</div>
							<div class="gallery-info">
								<div class="conference-badge dsa">Data Science Africa 2025</div>
								<h3>Responsible AI Frameworks for Africa</h3>
								<p>Presenting research on responsible AI frameworks for Africa</p>
								<div class="gallery-meta">
									<span class="gallery-date">June 2025</span>
									<span class="gallery-location">Nigeria</span>
								</div>
							</div>
						</div>
					</div>

					<!-- Research Activities -->
					<div class="gallery-item" data-category="research">
						<div class="gallery-card">
							<div class="research-visual agriculture">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M12 2L2 7l10 5 10-5-10-5z"/>
										<path d="M2 17l10 5 10-5"/>
										<path d="M2 12l10 5 10-5"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Agricultural AI Research</h4>
									<p>Precision crop management & quality assessment</p>
									<div class="research-metrics">
										<span class="metric">Deep Learning</span>
										<span class="metric">Computer Vision</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>Zanzibar Cloves Research</h3>
								<p>Field work and data collection for cloves quality grading project with Patrick Ndowo</p>
								<span class="gallery-date">2024-2025</span>
							</div>
						</div>
					</div>

					<div class="gallery-item" data-category="research">
						<div class="gallery-card">
							<div class="research-visual medical">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
										<circle cx="12" cy="12" r="3"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Medical Imaging AI</h4>
									<p>Healthcare diagnostics & neonatal care</p>
									<div class="research-metrics">
										<span class="metric">Medical AI</span>
										<span class="metric">Image Analysis</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>Placental Imaging Research</h3>
								<p>AI-powered medical image analysis for healthcare applications with Twamaa Makame</p>
								<span class="gallery-date">2024-2025</span>
							</div>
						</div>
					</div>

					<div class="gallery-item" data-category="research">
						<div class="gallery-card">
							<div class="research-visual assistive">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<circle cx="12" cy="12" r="3"/>
										<path d="M12 1v6m0 6v6"/>
										<path d="M21 12h-6m-6 0H3"/>
										<path d="M18.364 5.636L16.95 7.05"/>
										<path d="M7.05 16.95l-1.414 1.414"/>
										<path d="M5.636 5.636L7.05 7.05"/>
										<path d="M16.95 16.95l1.414 1.414"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Assistive Technology</h4>
									<p>Edge AI for accessibility solutions</p>
									<div class="research-metrics">
										<span class="metric">Edge AI</span>
										<span class="metric">Accessibility</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>E-Vision Development</h3>
								<p>Edge AI framework for assistive technologies with Shivam Vyas</p>
								<span class="gallery-date">2024-2025</span>
							</div>
						</div>
					</div>

					<!-- Lab Facilities -->
					<div class="gallery-item" data-category="lab">
						<div class="gallery-card">
							<div class="research-visual lab">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
										<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>SAAIL Laboratory</h4>
									<p>State-of-the-art research facilities</p>
									<div class="research-metrics">
										<span class="metric">AI Research</span>
										<span class="metric">Innovation Hub</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>Main Laboratory</h3>
								<p>State-of-the-art AI research facilities at IIT Madras Zanzibar</p>
								<span class="gallery-date">2025</span>
							</div>
						</div>
					</div>

					<div class="gallery-item" data-category="lab">
						<div class="gallery-card">
							<div class="research-visual computing">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
										<line x1="8" y1="21" x2="16" y2="21"/>
										<line x1="12" y1="17" x2="12" y2="21"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Computing Infrastructure</h4>
									<p>High-performance AI computing systems</p>
									<div class="research-metrics">
										<span class="metric">GPU Clusters</span>
										<span class="metric">ML Pipeline</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>High-Performance Computing</h3>
								<p>Advanced computing infrastructure for AI research and model training</p>
								<span class="gallery-date">2025</span>
							</div>
						</div>
					</div>

					<!-- Collaborations -->
					<div class="gallery-item" data-category="collaborations">
						<div class="gallery-card">
							<div class="research-visual collaboration">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
										<circle cx="9" cy="7" r="4"/>
										<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Global Partnerships</h4>
									<p>International research collaborations</p>
									<div class="research-metrics">
										<span class="metric">5+ Universities</span>
										<span class="metric">4 Countries</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>Deakin University Partnership</h3>
								<p>Cotutelle PhD program collaboration meetings and research planning</p>
								<span class="gallery-date">2025</span>
							</div>
						</div>
					</div>

					<div class="gallery-item" data-category="collaborations">
						<div class="gallery-card">
							<div class="research-visual medical-collab">
								<div class="research-icon-container">
									<svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
										<path d="M12 2v20"/>
										<circle cx="12" cy="12" r="2"/>
									</svg>
								</div>
								<div class="research-details">
									<h4>Medical AI Collaboration</h4>
									<p>Healthcare research partnerships</p>
									<div class="research-metrics">
										<span class="metric">Penn State</span>
										<span class="metric">PlacentaVision</span>
									</div>
								</div>
							</div>
							<div class="gallery-info">
								<h3>Penn State University</h3>
								<p>PlacentaVision medical imaging collaboration for neonatal care</p>
								<span class="gallery-date">2024-2025</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Upload Section -->
				<div class="upload-section">
					<div class="upload-card">
						<div class="upload-icon">
							<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-15a2 2 0 0 1 2-2h8"></path>
								<path d="M17 6l5 5-5 5"></path>
								<path d="M7 11h10"></path>
							</svg>
						</div>
						<h3>Share Your Research Moments</h3>
						<p>Have photos from SAAIL Lab events, research activities, or collaborative projects? We'd love to feature them in our gallery!</p>
						<a href="/contact" class="btn btn-primary">Submit Photos</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Poster Modal -->
		<div class="poster-modal" id="posterModal">
			<div class="modal-backdrop"></div>
			<div class="modal-content">
				<button class="modal-close" id="modalClose">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
				<img id="modalImage" src="" alt="" class="modal-image">
			</div>
		</div>
	</main>

	<ModernFooter />
</Layout>

<style>
	.gallery-page {
		padding-top: 90px;
	}

	.gallery-hero {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
		color: white;
		padding: 5rem 0;
		text-align: center;
		position: relative;
		overflow: hidden;
		box-shadow: inset 0 0 100px rgba(0, 0, 0, 0.1);
	}

	.gallery-hero::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="camera" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="10" cy="10" r="2" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23camera)"/></svg>');
		opacity: 0.3;
	}

	.hero-content {
		max-width: 800px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.hero-icon {
		color: white;
		margin-bottom: 2rem;
		animation: float 3s ease-in-out infinite, glow 4s ease-in-out infinite alternate;
	}

	.professional-icon {
		filter: drop-shadow(0 10px 30px rgba(102, 126, 234, 0.4));
		transition: all 0.3s ease;
	}

	.hero-content:hover .professional-icon {
		transform: scale(1.05);
		filter: drop-shadow(0 15px 40px rgba(102, 126, 234, 0.6));
	}

	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-10px); }
	}

	@keyframes glow {
		0% { filter: drop-shadow(0 10px 30px rgba(102, 126, 234, 0.4)); }
		100% { filter: drop-shadow(0 15px 50px rgba(118, 75, 162, 0.6)); }
	}

	.hero-content h1 {
		font-size: 3.5rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
		background: linear-gradient(135deg, #ffffff 0%, #f8fafc 50%, #ffffff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-description {
		font-size: 1.25rem;
		opacity: 0.9;
		line-height: 1.7;
		text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
		font-weight: 400;
		letter-spacing: 0.02em;
	}

	.gallery-content {
		padding: 5rem 0;
		background: var(--bg-primary);
	}

	.gallery-filters {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 4rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		padding: 1rem 2rem;
		background: var(--bg-secondary);
		color: var(--text-secondary);
		border: 2px solid var(--border-color);
		border-radius: 50px;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	.filter-btn::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
		transition: left 0.5s;
	}

	.filter-btn:hover::before {
		left: 100%;
	}

	.filter-btn:hover,
	.filter-btn.active {
		background: linear-gradient(135deg, var(--accent-blue) 0%, #3b82f6 100%);
		color: white;
		border-color: var(--accent-blue);
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(var(--accent-blue-rgb), 0.3);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
		gap: 2.5rem;
		margin-bottom: 4rem;
	}

	.gallery-item {
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.gallery-item.featured {
		grid-column: span 1;
	}

	.gallery-card {
		background: var(--bg-secondary);
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 8px 32px var(--shadow-light);
		border: 1px solid var(--border-color);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
	}

	.gallery-card:hover {
		transform: translateY(-8px) scale(1.02);
		box-shadow: 0 20px 60px var(--shadow-medium);
	}

	.poster-card {
		cursor: pointer;
	}

	.poster-container {
		position: relative;
		height: 350px;
		overflow: hidden;
	}

	.poster-image {
		width: 100%;
		height: 100%;
		object-fit: contain;
		background: white;
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.poster-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(30, 58, 138, 0.9) 0%, rgba(59, 130, 246, 0.9) 100%);
		color: white;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		backdrop-filter: blur(10px);
	}

	.poster-card:hover .poster-overlay {
		opacity: 1;
	}

	.poster-card:hover .poster-image {
		transform: scale(1.1);
	}

	.zoom-icon {
		margin-bottom: 1rem;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.1); }
	}

	.poster-overlay p {
		font-weight: 600;
		font-size: 1.125rem;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
	}

	.research-visual {
		height: 280px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
		padding: 2rem;
		text-align: center;
	}

	.research-visual.agriculture {
		background: linear-gradient(135deg, #059669 0%, #047857 100%);
		color: white;
	}

	.research-visual.medical {
		background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
		color: white;
	}

	.research-visual.assistive {
		background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
		color: white;
	}

	.research-visual.lab {
		background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
		color: white;
	}

	.research-visual.computing {
		background: linear-gradient(135deg, #374151 0%, #1f2937 100%);
		color: white;
	}

	.research-visual.collaboration {
		background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
		color: white;
	}

	.research-visual.medical-collab {
